<script>
  // Rede de segurança: se algo falhar ao carregar antes do React desenhar a tela,
  // mostra uma mensagem de erro visível em vez de deixar a página em branco/preta.
  window.addEventListener('error', function(e){
    var root = document.getElementById('root');
    if(root && !root.hasChildNodes()){
      root.innerHTML = '<div style="max-width:640px;margin:80px auto;padding:28px;background:#191927;border:1px solid #ff3d9a;border-radius:14px;color:#e9e7f7;font-family:sans-serif;line-height:1.6;">' +
        '<h2 style="color:#ff3d9a;margin-bottom:12px;">Erro ao carregar o sistema</h2>' +
        '<p>' + (e.message || 'Erro desconhecido') + '</p>' +
        '<p style="color:#8d8ba8;font-size:13px;margin-top:14px;">Abra o console do navegador (F12 → Console) e me mande um print da mensagem em vermelho.</p>' +
        '</div>';
    }
  });
</script>

<style>
/* ============================================================
   OS ESCOLHIDOS — design tokens (mesmo tema do sistema anterior)
   ============================================================ */
*{ box-sizing:border-box; margin:0; padding:0; }
:root{
  --bg:#0a0a12; --panel:#12121e; --panel-raised:#191927; --border:#2a2a3d;
  --purple:#8b3ffb; --purple-deep:#5a1fb0; --cyan:#29e0ff; --magenta:#ff3d9a; --gold:#ffd23f;
  --text:#e9e7f7; --muted:#8d8ba8;
  --font-display:'Cinzel',serif; --font-ui:'Rajdhani',sans-serif;
}
html,body,#root{ min-height:100vh; }
body{ background:var(--bg); color:var(--text); font-family:var(--font-ui); }
button, input, textarea, select{ font-family:var(--font-ui); }
button{ cursor:pointer; }
::-webkit-scrollbar{ width:8px; }
::-webkit-scrollbar-track{ background:var(--bg); }
::-webkit-scrollbar-thumb{ background:var(--purple-deep); border-radius:10px; }

.bg-fx{ position:fixed; inset:0; z-index:-1; overflow:hidden; }
.glow{ position:absolute; width:60vw; height:60vw; border-radius:50%; filter:blur(120px); opacity:.25; }
.glow-purple{ background:var(--purple); top:-20%; left:-15%; }
.glow-blue{ background:var(--cyan); bottom:-25%; right:-10%; }

/* topbar */
.topbar{ position:sticky; top:0; z-index:50; display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:12px; padding:14px 26px; background:rgba(10,10,18,.8); backdrop-filter:blur(10px); border-bottom:1px solid var(--border); }
.brand{ display:flex; align-items:center; gap:10px; }
.brand-mark{ font-size:20px; color:var(--purple); text-shadow:0 0 12px var(--purple); }
.brand-text{ font-family:var(--font-display); font-weight:900; letter-spacing:3px; font-size:18px;
  background:linear-gradient(90deg,var(--purple),var(--cyan)); -webkit-background-clip:text; background-clip:text; color:transparent; }
.main-nav{ display:flex; gap:6px; flex-wrap:wrap; align-items:center; }
.nav-btn{ background:transparent; border:1px solid transparent; color:var(--muted); padding:8px 14px; border-radius:8px;
  font-weight:600; font-size:14px; transition:all .2s ease; }
.nav-btn:hover{ color:var(--text); border-color:var(--border); background:var(--panel); }
.nav-btn.active{ color:var(--bg); background:linear-gradient(90deg,var(--purple),var(--cyan)); }
.who{ font-size:13px; color:var(--muted); display:flex; align-items:center; gap:10px; }
.online-panel{ position:absolute; right:0; top:calc(100% + 8px); min-width:180px; background:var(--bg2); border:1px solid var(--border);
  border-radius:12px; padding:10px 14px; z-index:60; box-shadow:0 8px 32px rgba(0,0,0,.5); }
.nav-account{ display:none; }
.role-pill{ font-size:11px; font-weight:700; padding:3px 9px; border-radius:20px; letter-spacing:.5px; text-transform:uppercase; }
.role-admin{ background:rgba(255,61,154,.18); color:var(--magenta); }
.role-player{ background:rgba(41,224,255,.15); color:var(--cyan); }
.nav-burger{ display:none; flex-direction:column; justify-content:center; gap:4px; width:34px; height:34px; background:transparent; border:1px solid var(--border); border-radius:8px; margin-left:auto; }
.nav-burger span{ display:block; width:16px; height:2px; background:var(--text); margin:0 auto; border-radius:2px; }
.nav-scrim{ display:none; }

main{ max-width:1180px; margin:0 auto; padding:36px 22px 100px; }
.section-title{ font-family:var(--font-display); font-size:24px; letter-spacing:1px; margin-bottom:24px; display:flex; align-items:center; gap:12px; }
.section-title .tag{ font-size:12px; font-weight:700; color:var(--bg); background:var(--cyan); padding:3px 8px; border-radius:5px; }

.btn-primary{ background:linear-gradient(90deg,var(--purple),var(--cyan)); color:#05050a; border:none; padding:11px 22px;
  border-radius:9px; font-weight:700; font-size:14px; box-shadow:0 0 20px rgba(139,63,251,.35); transition:transform .15s ease; }
.btn-primary:hover{ transform:translateY(-2px); }
.btn-primary:disabled{ opacity:.4; cursor:not-allowed; transform:none; }
.btn-ghost{ background:transparent; color:var(--text); border:1px solid var(--border); padding:11px 22px; border-radius:9px; font-weight:700; font-size:14px; }
.btn-ghost:hover{ border-color:var(--purple); color:var(--purple); }
.btn-sm{ padding:7px 14px; font-size:13px; border-radius:7px; }
.btn-danger{ background:transparent; border:1px solid var(--magenta); color:var(--magenta); padding:8px 16px; border-radius:8px; font-weight:700; font-size:13px; }

input[type=text], input[type=email], input[type=password], input[type=number], textarea, select{
  background:#05050a; border:1px solid var(--border); color:var(--text); padding:10px 12px; border-radius:8px;
  font-size:14px; width:100%; outline:none; }
input:focus, textarea:focus, select:focus{ border-color:var(--purple); }
label{ font-size:12px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; display:block; margin-bottom:6px; }
.field{ margin-bottom:14px; }

/* splash / auth */
.splash{ min-height:100vh; display:flex; align-items:center; justify-content:center; flex-direction:column; text-align:center; padding:20px; }
.splash-title{ font-family:var(--font-display); font-weight:900; letter-spacing:6px; font-size:clamp(38px,9vw,78px);
  background:linear-gradient(120deg,var(--text) 10%,var(--purple) 45%,var(--cyan) 80%); -webkit-background-clip:text; background-clip:text; color:transparent;
  text-shadow:0 0 60px rgba(139,63,251,.25); margin-bottom:8px; }
.splash-sub{ color:var(--muted); letter-spacing:3px; font-size:13px; text-transform:uppercase; margin-bottom:40px; }
.auth-card{ background:var(--panel); border:1px solid var(--border); border-radius:18px; padding:32px; width:100%; max-width:380px; text-align:left; }
.auth-tabs{ display:flex; gap:8px; margin-bottom:20px; }
.auth-tab{ flex:1; background:transparent; border:1px solid var(--border); color:var(--muted); padding:9px; border-radius:8px; font-weight:700; }
.auth-tab.active{ background:linear-gradient(90deg,var(--purple),var(--cyan)); color:#05050a; border-color:transparent; }
.auth-error{ color:var(--magenta); font-size:13px; margin-bottom:12px; }
.auth-msg{ color:var(--cyan); font-size:13px; margin-bottom:12px; }

/* home / story feed */
.story-post{ background:var(--panel); border:1px solid var(--border); border-radius:14px; padding:20px; margin-bottom:16px; }
.story-meta{ font-size:12px; color:var(--muted); margin-bottom:8px; display:flex; justify-content:space-between; }
.story-content{ font-size:15px; line-height:1.7; white-space:pre-wrap; }
.story-loc{ display:inline-block; margin-top:10px; font-size:12px; color:var(--gold); }
.composer{ background:var(--panel-raised); border:1px solid var(--border); border-radius:14px; padding:20px; margin-bottom:26px; }

/* character grid + bio */
.char-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:20px; }
.char-card{ background:linear-gradient(160deg,var(--panel-raised),var(--panel)); border:1px solid var(--border); border-radius:16px;
  padding:0; overflow:hidden; cursor:pointer; transition:transform .2s ease, box-shadow .2s ease; }
.char-card:hover{ transform:translateY(-5px); box-shadow:0 14px 34px rgba(0,0,0,.5); }
.char-avatar-wrap{ position:relative; width:100%; height:170px; overflow:hidden; background:#05050a; }
.char-avatar-bg{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:blur(18px) brightness(.5) saturate(1.15); transform:scale(1.25); display:block; }
.char-avatar{ position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center center; display:block; background:transparent; }
.char-avatar-placeholder{ width:100%; height:170px; display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:40px; color:var(--purple); background:#05050a; }
.char-card-body{ padding:16px 18px; }
.card-top{ display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px; }
.card-name{ font-family:var(--font-display); font-size:17px; font-weight:700; }
.card-power{ color:var(--muted); font-size:12.5px; margin-top:3px; }
.rank-badge{ width:34px; height:34px; display:flex; align-items:center; justify-content:center; font-family:var(--font-display);
  font-weight:900; font-size:15px; transform:rotate(45deg); border-radius:7px; flex-shrink:0; }
.rank-badge span{ transform:rotate(-45deg); }
.rank-S{ background:linear-gradient(135deg,var(--magenta),#7a0d3f); color:#fff; }
.rank-A{ background:linear-gradient(135deg,var(--gold),#a67a00); color:#1a1200; }
.rank-B{ background:linear-gradient(135deg,var(--cyan),#0d7a8a); color:#001a1a; }
.rank-C{ background:linear-gradient(135deg,#8d8ba8,#3a3850); color:#fff; }
.card-desc{ font-size:13px; color:var(--muted); line-height:1.5; }

/* Carrossel de heróis (tela inicial, estilo Overwatch) */
.hero-splash{ position:relative; width:100%; height:clamp(320px,52vw,480px); border-radius:20px; overflow:hidden; margin-bottom:32px;
  background:linear-gradient(160deg,var(--panel-raised),#05050a); border:1px solid var(--border); }
.hero-splash-bg{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:blur(32px) brightness(.5) saturate(1.15); transform:scale(1.2); display:block; }
.hero-splash-img{ position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center center; display:block; }
.hero-splash-placeholder{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:96px; color:var(--purple); }
.hero-splash-scrim{ position:absolute; inset:0; pointer-events:none;
  background:linear-gradient(0deg, rgba(5,5,10,.95) 10%, rgba(5,5,10,.35) 48%, transparent 78%),
    linear-gradient(90deg, rgba(5,5,10,.5) 0%, transparent 32%); }
.hero-splash-content{ position:absolute; left:0; right:0; bottom:0; padding:26px 90px 26px 32px; }
.hero-splash-eyebrow{ font-family:var(--font-display); font-size:11px; letter-spacing:3px; color:var(--gold); text-transform:uppercase; margin-bottom:6px; }
.hero-splash-name{ font-family:var(--font-display); font-weight:900; font-size:clamp(26px,4vw,40px); text-shadow:0 4px 20px rgba(0,0,0,.8); }
.hero-splash-meta{ color:var(--cyan); font-size:13.5px; margin-top:4px; }
.hero-splash-story{ margin-top:10px; max-width:560px; font-size:14px; line-height:1.6; color:var(--muted); }
.hero-splash-cta{ margin-top:14px; }
.hero-splash-nav{ position:absolute; top:0; bottom:0; width:70px; display:flex; align-items:center; justify-content:center;
  background:transparent; border:none; color:#fff; cursor:pointer; z-index:5; opacity:.5; transition:opacity .2s ease, background .2s ease; }
.hero-splash-nav:hover{ opacity:1; background:rgba(5,5,10,.28); }
.hero-splash-nav.prev{ left:0; }
.hero-splash-nav.next{ right:0; }
.hero-splash-nav svg{ width:34px; height:34px; filter:drop-shadow(0 2px 6px rgba(0,0,0,.6)); }
.hero-splash-dots{ position:absolute; top:16px; right:16px; display:flex; gap:6px; z-index:4; }
.hero-splash-dot{ width:7px; height:7px; border-radius:50%; background:rgba(255,255,255,.35); cursor:pointer; transition:background .2s, transform .2s; }
.hero-splash-dot.active{ background:var(--gold); transform:scale(1.35); }

/* Galeria de heróis (aba Personagens, estilo seleção do Overwatch) */
.hero-gallery{ display:flex; flex-direction:column; gap:14px; margin-bottom:30px; }
.hero-gallery-stage{ position:relative; height:clamp(240px,38vw,360px); border-radius:16px; overflow:hidden;
  background:linear-gradient(160deg,var(--panel-raised),#05050a); border:1px solid var(--border); }
.hero-gallery-bg{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:blur(28px) brightness(.5) saturate(1.15); transform:scale(1.2); display:block; }
.hero-gallery-img{ position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center center; display:block; }
.hero-gallery-scrim{ position:absolute; inset:0; pointer-events:none;
  background:linear-gradient(100deg, rgba(5,5,10,.92) 0%, rgba(5,5,10,.55) 42%, transparent 72%); }
.hero-gallery-info{ position:absolute; left:26px; top:50%; transform:translateY(-50%); max-width:300px; z-index:2; }
.hero-gallery-role{ font-family:var(--font-display); font-size:11px; letter-spacing:3px; color:var(--gold); text-transform:uppercase; }
.hero-gallery-name{ font-family:var(--font-display); font-weight:900; font-size:clamp(21px,3.2vw,28px); margin-top:4px; }
.hero-gallery-power{ color:var(--cyan); font-size:13px; margin-top:6px; }
.hero-gallery-desc{ font-size:13px; color:var(--muted); margin-top:9px; line-height:1.5; }
.hero-gallery-open{ margin-top:13px; }
.hero-gallery-strip{ display:flex; gap:8px; flex-wrap:wrap; }
.hero-square{ width:56px; height:56px; border-radius:8px; overflow:hidden; cursor:pointer; border:2px solid transparent;
  background:#05050a; flex-shrink:0; transition:border-color .15s ease, transform .15s ease; position:relative; }
.hero-square img{ width:100%; height:100%; object-fit:cover; display:block; }
.hero-square-placeholder{ width:100%; height:100%; display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:18px; color:var(--purple); }
.hero-square:hover{ transform:translateY(-2px); }
.hero-square.active{ border-color:var(--gold); transform:translateY(-3px); }
@media (max-width:860px){
  /* header / navegação */
  .topbar{ padding:12px 16px; gap:8px; }
  .brand{ flex:1 1 auto; }
  .brand-text{ font-size:16px; }
  .nav-burger{ display:flex; }
  .nav-scrim{ display:block; position:fixed; inset:0; background:rgba(5,5,10,.72); backdrop-filter:blur(2px); z-index:150; }
  .main-nav{ position:fixed; top:0; right:0; bottom:0; width:min(280px,82vw); flex-direction:column; align-items:stretch;
    background:var(--bg2); border-left:1px solid var(--border); padding:76px 16px 24px; gap:4px;
    transform:translateX(100%); transition:transform .25s ease; z-index:200; overflow-y:auto; }
  .main-nav.open{ transform:translateX(0); box-shadow:-16px 0 50px rgba(0,0,0,.55); }
  .main-nav .nav-btn{ width:100%; text-align:left; padding:12px 14px; font-size:15px; border:1px solid var(--border); }
  .main-nav .nav-btn.active{ border-color:transparent; }
  .who{ display:none; } /* no mobile o conteúdo da conta mora dentro do menu (.nav-account) */
  .nav-account{ display:flex; flex-direction:column; align-items:flex-start; gap:10px; margin-top:18px; padding-top:16px; border-top:1px solid var(--border); }
  .nav-account .who-name{ font-size:13px; color:var(--muted); }
  .online-panel{ left:0; right:auto; }

  /* conteúdo geral */
  main{ padding:20px 14px 90px; }
  .section-title{ font-size:19px; margin-bottom:18px; }
  .grid2{ grid-template-columns:1fr; }
  .attr-grid{ gap:6px; }
  .attr-grid .attr-value{ font-size:16px; }
  .char-grid{ grid-template-columns:1fr; }

  /* abas (Sobre / Ficha & EXP / Habilidades / Inventário / Histórico) viram scroll horizontal */
  .tabs{ flex-wrap:nowrap; overflow-x:auto; -webkit-overflow-scrolling:touch; padding-bottom:8px; }
  .tabs::-webkit-scrollbar{ height:0; }
  .tabs button{ flex-shrink:0; }

  /* modais ocupam a tela quase toda, sem margem lateral grande */
  .overlay{ padding:10px; }
  .sheet{ padding:18px; border-radius:16px; }
  .sheet-hero{ margin:-18px -18px 16px; width:calc(100% + 36px); height:210px; }

  /* carrossel/galeria de heróis */
  .hero-splash-content{ padding:20px; }
  .hero-splash-nav{ width:44px; }
  .hero-splash-name{ font-size:24px; }
  .hero-gallery-info{ position:static; transform:none; max-width:none; padding:16px 18px 0; }
  .hero-gallery-stage{ height:auto; padding-bottom:12px; }
  .hero-gallery-img{ position:relative; height:200px; }
  .hero-gallery-scrim{ display:none; }
  .hero-square{ width:48px; height:48px; }

  /* botões e formulários ficam mais fáceis de tocar */
  .btn-primary, .btn-ghost{ padding:10px 16px; font-size:13.5px; }
  input[type=text], input[type=email], input[type=password], input[type=number], textarea, select{ font-size:16px; } /* evita zoom automático no iOS */
  .chat-box{ height:min(65vh,460px); padding:12px; }
  .chat-msg{ max-width:88%; }
  .newspaper-body{ padding:18px 18px 20px; }
  .newspaper-title{ font-size:21px; }
  .newspaper-headline{ font-size:19px; }
}
@media (max-width:420px){
  .attr-grid{ grid-template-columns:1fr 1fr; }
  .attr-grid > div:last-child{ grid-column:1 / -1; }
  .who{ gap:6px; }
}

.overlay{ position:fixed; inset:0; background:rgba(5,5,10,.85); backdrop-filter:blur(6px); display:none; align-items:center;
  justify-content:center; z-index:100; padding:20px; overflow-y:auto; }
.overlay.open{ display:flex; }
.sheet{ background:linear-gradient(165deg,var(--panel-raised),var(--panel)); border:1px solid var(--border); border-radius:20px;
  max-width:680px; width:100%; overflow:hidden; padding:28px; position:relative; margin:auto 0; }
.sheet-close{ position:absolute; top:16px; right:18px; background:rgba(5,5,10,0.6); width:32px; height:32px; border-radius:50%; border:none; color:var(--text); font-size:18px; z-index:10; display:flex; align-items:center; justify-content:center; }
.sheet-close:hover{ color:var(--magenta); }
.sheet-hero{ position:relative; width:calc(100% + 56px); margin:-28px -28px 20px; border-radius:20px 20px 0 0; overflow:hidden; height:280px; background:#05050a; }
.sheet-hero-img{ width:100%; height:100%; object-fit:cover; display:block; }
.sheet-hero-placeholder{ display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-size:64px; color:var(--purple); background:linear-gradient(160deg,var(--panel-raised),#05050a); }
.sheet-hero-overlay{ position:absolute; left:0; right:0; bottom:0; padding:20px 24px; display:flex; align-items:center; gap:14px;
  background:linear-gradient(0deg, rgba(5,5,10,0.92) 10%, rgba(5,5,10,0.55) 55%, transparent 100%); }
.sheet-hero-overlay .rank-badge{ width:48px; height:48px; flex-shrink:0; }
.sheet-hero-upload{ position:absolute; top:14px; left:14px; }
.sheet-name{ font-family:var(--font-display); font-size:24px; font-weight:700; text-shadow:0 2px 12px rgba(0,0,0,0.8); }
.sheet-power{ color:var(--cyan); font-size:13.5px; margin-top:3px; text-shadow:0 2px 8px rgba(0,0,0,0.8); }
.tabs{ display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; border-bottom:1px solid var(--border); padding-bottom:10px; }
.tab-btn{ background:transparent; border:none; color:var(--muted); font-weight:700; font-size:13px; padding:6px 10px; border-radius:6px; }
.tab-btn.active{ color:var(--cyan); background:rgba(41,224,255,.1); }
.tab-panel{ font-size:14px; line-height:1.7; color:var(--text); }
.tab-panel .muted{ color:var(--muted); }

.stat-row{ display:flex; justify-content:space-between; font-size:13px; color:var(--muted); margin-bottom:5px; }
.stat-row b{ color:var(--text); }
