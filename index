<script>
(function(){
  if (window.__osEscolhidosBooted) { return; }
  window.__osEscolhidosBooted = true;
"use strict";
// @ts-nocheck
const { useState, useEffect, useRef, useMemo } = React;
if (!window.supabase || !window.supabase.createClient) {
    throw new Error('Biblioteca do Supabase não carregou. Verifique sua conexão ou o link do script no <head>.');
}
if (window.SUPABASE_URL.indexOf('SEU-PROJETO') !== -1) {
    throw new Error('Configure o SUPABASE_URL e SUPABASE_ANON_KEY no topo do arquivo index.html antes de usar o sistema.');
}
// corrige automaticamente se alguém colar a URL da API REST em vez da Project URL
window.SUPABASE_URL = window.SUPABASE_URL.replace(/\/rest\/v1\/?$/, '');
const supabase = window.supabase.createClient(window.SUPABASE_URL, window.SUPABASE_ANON_KEY);
/* ============================================================
   UTIL
   ============================================================ */
function useToast() {
    const [msg, setMsg] = useState(null);
    function show(text) {
        setMsg(text);
        clearTimeout(show._t);
        show._t = setTimeout(() => setMsg(null), 2600);
    }
    return [msg, show];
}
function rankClass(r) { return 'rank-' + (r || 'A'); }
function attrModifier(v) { return Math.floor((v - 50) / 10); }
function initialsOf(name) { return (name || '?').slice(0, 2).toUpperCase(); }
// remove acentos, espaços e caracteres especiais do nome do arquivo antes de subir pro Storage
function sanitizeFileName(name) {
    const noAccents = name.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    return noAccents.replace(/[^a-zA-Z0-9.\-]/g, '_');
}
/* ============================================================
   AUTENTICAÇÃO / TELA DE ABERTURA
   ============================================================ */
// converte um nome de usuário num "e-mail" técnico interno (nunca é usado pra enviar nada)
function usernameToEmail(username) {
    const slug = username.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
    return slug + '@escolhidos.app';
}
function AuthScreen() {
    const [mode, setMode] = useState('login');
    const [username, setUsername] = useState('');
    const [password, setPassword] = useState('');
    const [error, setError] = useState('');
    const [info, setInfo] = useState('');
    const [busy, setBusy] = useState(false);
    async function submit(e) {
        e.preventDefault();
        setError('');
        setInfo('');
        setBusy(true);
        try {
            if (!username.trim()) {
                throw new Error('Digite um nome de usuário.');
            }
            const email = usernameToEmail(username);
            if (mode === 'login') {
                const { error } = await supabase.auth.signInWithPassword({ email, password });
                if (error)
                    throw error;
            }
            else {
                const { data, error } = await supabase.auth.signUp({ email, password });
                if (error)
                    throw error;
                if (data.user) {
